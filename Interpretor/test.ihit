struct x{
    name:String,
    age:int
};

fn factorial(n:i64) -> i64{
    let mut ret = n;
    for i in 1..n{
        ret *= i;
    }
    return ret;
}

fn main (x: int, z: float) {

let mut a = 10;
let mut b = 0;
let y = "pls"; 
scan(a,b);
for i in a..b{
    println("{}:{}",i,factorial(i));
}


}
